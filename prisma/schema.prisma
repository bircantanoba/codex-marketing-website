generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum ContentType {
  PRODUCT
  ARTICLE
  BLOG
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  contentTranslations     ContentTranslation[]
  siteSettingTranslations SiteSettingTranslation[]
}

model Content {
  id          String      @id @default(cuid())
  type        ContentType
  category    String?
  imageUrl    String?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  translations ContentTranslation[]
}

model ContentTranslation {
  id          String   @id @default(cuid())
  contentId   String
  languageId  String
  slug        String
  title       String
  description String?
  bodyHtml    String

  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, slug])
  @@unique([contentId, languageId])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations SiteSettingTranslation[]
}

model SiteSettingTranslation {
  id            String   @id @default(cuid())
  siteSettingId String
  languageId    String
  value         String

  siteSetting SiteSetting @relation(fields: [siteSettingId], references: [id], onDelete: Cascade)
  language    Language    @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([siteSettingId, languageId])
}
